<Window x:Class="HanziOverlay.App.Windows.ControlWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HanziOverlay" Height="420" Width="340"
        WindowStartupLocation="Manual" Left="50" Top="50"
        ResizeMode="CanResizeWithGrip" Closing="Window_Closing">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0">
            <Button x:Name="SelectRegionButton" Content="Select Region (Ctrl+Alt+S)" Margin="0,0,0,4" Click="SelectRegionButton_Click"/>
            <StackPanel Orientation="Horizontal">
                <Button x:Name="PauseResumeButton" Content="Pause" Margin="0,0,4,0" Click="PauseResumeButton_Click"/>
                <Button x:Name="FreezeButton" Content="Freeze" Margin="0,0,4,0" Click="FreezeButton_Click"/>
                <Button x:Name="ToggleCnButton" Content="Toggle CN" Margin="0,0,4,0" Click="ToggleCnButton_Click"/>
                <Button x:Name="SaveButton" Content="Save" Margin="0,0,4,0" Click="SaveButton_Click"/>
                <Button x:Name="ExportButton" Content="Export" Click="ExportButton_Click"/>
            </StackPanel>
        </StackPanel>
        <StackPanel Grid.Row="1" Margin="0,8,0,0">
            <TextBlock Text="FPS:"/>
            <ComboBox x:Name="FpsCombo" SelectedIndex="1" SelectionChanged="FpsCombo_SelectionChanged">
                <ComboBoxItem Content="3"/>
                <ComboBoxItem Content="6"/>
                <ComboBoxItem Content="10"/>
            </ComboBox>
            <TextBlock Text="Opacity:" Margin="0,4,0,0"/>
            <Slider x:Name="OpacitySlider" Minimum="0.2" Maximum="1" Value="0.85" TickFrequency="0.1" ValueChanged="OpacitySlider_ValueChanged"/>
            <CheckBox x:Name="CloudTranslationCheck" Content="Cloud translation" Margin="0,4,0,0" Checked="CloudTranslationCheck_Changed" Unchecked="CloudTranslationCheck_Changed"/>
        </StackPanel>
        <TextBlock Grid.Row="2" Text="History (last 30 lines)" Margin="0,8,0,0" VerticalAlignment="Top"/>
        <ListBox Grid.Row="2" x:Name="HistoryList" Margin="0,24,0,0" DisplayMemberPath="CnText" SelectionChanged="HistoryList_SelectionChanged"/>
    </Grid>
</Window>
