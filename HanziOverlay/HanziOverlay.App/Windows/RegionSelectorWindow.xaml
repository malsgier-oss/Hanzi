<Window x:Class="HanziOverlay.App.Windows.RegionSelectorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select region - drag to select, ESC to cancel" WindowStyle="None" AllowsTransparency="True"
        Background="#40000000" WindowState="Maximized" Topmost="True"
        Cursor="Cross" KeyDown="OnKeyDown"
        MouseLeftButtonDown="OnMouseLeftButtonDown"
        MouseLeftButtonUp="OnMouseLeftButtonUp"
        MouseMove="OnMouseMove">
    <Canvas x:Name="Canvas">
        <Rectangle x:Name="SelectionRect" Stroke="Red" StrokeThickness="2" Fill="#20FF0000" Visibility="Collapsed"/>
    </Canvas>
</Window>
